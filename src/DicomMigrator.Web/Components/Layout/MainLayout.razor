@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthState
@inject ILocalConfigRepository ConfigRepo
@inject NavigationManager Nav
@implements IDisposable

<div class="app-shell">
    <nav class="sidebar">
        <div class="sidebar-logo">
            <MoveLogo Variant="horizontal" Size="19" Color="var(--text)" TaglineColor="var(--text-dim)" />
        </div>

        <div class="nav-group">
            <div class="nav-group-label">Principal</div>
            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="nav-icon">◈</span> Dashboard
            </NavLink>
        </div>

        <div class="nav-group">
            <div class="nav-group-label">Migración</div>
            <NavLink class="nav-item" href="/migraciones">
                <span class="nav-icon">⇄</span> Migraciones
            </NavLink>
            <NavLink class="nav-item" href="/discovery">
                <span class="nav-icon">🔍</span> Discovery Engine
            </NavLink>
            <AuthorizeView Roles="@AppRoles.Administrador" Context="adm">
                <NavLink class="nav-item" href="/nodos">
                <span class="nav-icon">⊞</span> Nodos DICOM
            </NavLink>
            </AuthorizeView>
            <NavLink class="nav-item" href="/diagnostico">
                <span class="nav-icon">🔬</span> Diagnóstico
            </NavLink>
        </div>

        <div class="nav-group">
            <div class="nav-group-label">Sistema</div>
            <NavLink class="nav-item" href="/logs">
                <span class="nav-icon">⌨</span> Logs y auditoría
            </NavLink>
            <AuthorizeView Roles="@AppRoles.Administrador" Context="adm2">
                <NavLink class="nav-item" href="/localconfig">
                    <span class="nav-icon">⚙</span> Config. local SCU
                </NavLink>
                <NavLink class="nav-item" href="/usuarios">
                    <span class="nav-icon">👤</span> Usuarios
                </NavLink>
            </AuthorizeView>
            <NavLink class="nav-item" href="/ayuda">
                <span class="nav-icon">?</span> Ayuda
            </NavLink>
            <NavLink class="nav-item" href="/about">
                <span class="nav-icon">ℹ</span> Acerca de
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div style="padding:10px 14px;border-top:1px solid var(--border);
                            display:flex;align-items:center;gap:8px">
                    <span style="width:26px;height:26px;border-radius:50%;flex-shrink:0;
                                 background:rgba(167,139,250,.15);color:var(--purple);
                                 display:flex;align-items:center;justify-content:center;
                                 font-size:11px;font-weight:700">
                        @(Initials(context.User))
                    </span>
                    <span style="min-width:0;line-height:1.25">
                        <span style="display:block;font-size:11.5px;color:var(--text);
                                     overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @DisplayName(context.User)
                        </span>
                        <span style="display:block;font-size:9.5px;color:var(--text-muted)">
                            @RoleOf(context.User)
                        </span>
                    </span>
                    @* POST y no enlace: cerrar sesión modifica estado, y así queda
                       protegido por el antiforgery. *@
                    <form method="post" action="/logout" style="margin-left:auto">
                        <AntiforgeryToken />
                        <button type="submit" title="Cerrar sesión"
                                style="background:none;border:1px solid var(--border);color:var(--text-dim);
                                       border-radius:5px;width:26px;height:26px;cursor:pointer;font-size:12px">
                            ⏻
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="sidebar-footer">
            fo-dicom v5.2 · .NET 9<br />
            <span class="mono" style="color:var(--accent)">@_aet</span> · :@_port
        </div>
    </nav>

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private string _aet  = "MIGRATOR_SCU";
    private int    _port = 11113;

    protected override async Task OnInitializedAsync()
    {
        // Contraseña pendiente de cambio: no se puede usar la aplicación hasta hacerlo.
        // Comprobarlo aquí (y no solo al entrar) cierra la vía de navegar a mano a otra URL.
        var auth = await AuthState.GetAuthenticationStateAsync();
        if (auth.User.HasClaim("must_change_pwd", "1")
            && !Nav.Uri.Contains("/cambiar-password", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/cambiar-password", forceLoad: true);
            return;
        }

        await LoadConfig();
        Nav.LocationChanged += OnLocationChanged;
    }

    async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadConfig();
        await InvokeAsync(StateHasChanged);
    }

    // ── Identidad mostrada en el pie de la barra lateral ──
    static string DisplayName(System.Security.Claims.ClaimsPrincipal u)
        => u.FindFirst("display_name")?.Value
           ?? u.Identity?.Name
           ?? "usuario";

    static string RoleOf(System.Security.Claims.ClaimsPrincipal u)
        => u.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

    static string Initials(System.Security.Claims.ClaimsPrincipal u)
    {
        var name = DisplayName(u).Trim();
        if (string.IsNullOrEmpty(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}"
            : char.ToUpperInvariant(name[0]).ToString();
    }

    async Task LoadConfig()
    {
        var cfg = await ConfigRepo.GetAsync();
        _aet  = cfg.LocalAet;
        _port = cfg.LocalPort;
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
