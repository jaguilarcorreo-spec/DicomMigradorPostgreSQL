@* ════════════════════════════════════════════════════════════════════════════
   DateRangePicker.razor
   Selector de rango de fechas con calendario doble y atajos.
   Uso:  <DateRangePicker @bind-Start="_eStart" @bind-End="_eEnd" />
   Sin dependencias externas ni JS: el cierre "al hacer clic fuera" se resuelve
   con un backdrop transparente por debajo del popup.
   Los estilos van EMBEBIDOS aquí a propósito: el proyecto no usa CSS isolation
   ni cache-busting, así que depender de app.css hace el componente frágil.
   ════════════════════════════════════════════════════════════════════════════ *@

<style>
    .dp-root { position: relative; }

    .dp-field {
        display: flex; align-items: center; gap: 10px; cursor: pointer;
        background: var(--bg); border: 1px solid var(--border); border-radius: var(--r);
        padding: 8px 11px; user-select: none; font-family: var(--font-mono);
        position: relative; z-index: 1; max-width: 340px;
    }
    .dp-field:hover     { border-color: var(--border2); }
    .dp-field.dp-open   { border-color: var(--purple); box-shadow: 0 0 0 3px rgba(167,139,250,.12); }
    .dp-field.dp-disabled { opacity: .55; cursor: not-allowed; }
    .dp-field .dp-ico   { color: var(--purple); font-size: 13px; line-height: 1; }
    .dp-field .dp-val   { font-size: 13px; color: var(--text); letter-spacing: .02em; }
    .dp-field .dp-arrow { color: var(--text-muted); }
    .dp-field .dp-chev  { margin-left: auto; color: var(--text-muted); font-size: 10px; }

    .dp-backdrop { position: fixed; inset: 0; z-index: 40; background: transparent; }

    .dp-pop {
        position: absolute; top: calc(100% + 6px); left: 0; z-index: 50;
        background: var(--panel); border: 1px solid var(--border2); border-radius: var(--r2);
        box-shadow: 0 18px 40px rgba(0,0,0,.55); overflow: hidden; width: max-content;
    }
    .dp-body { display: flex; }

    .dp-side {
        width: 172px; border-right: 1px solid var(--border); padding: 12px 10px;
        display: flex; flex-direction: column; gap: 2px; background: rgba(0,0,0,.15);
    }
    .dp-side-hdr {
        font-size: 10px; letter-spacing: .08em; text-transform: uppercase;
        color: var(--text-muted); padding: 4px 8px 8px;
    }
    .dp-sc {
        text-align: left; background: none; border: 0; color: var(--text-dim);
        padding: 7px 9px; border-radius: 5px; font-size: 12.5px; cursor: pointer;
        font-family: var(--font-ui);
    }
    .dp-sc:hover { background: rgba(167,139,250,.10); color: var(--purple); }

    .dp-cals { display: flex; gap: 22px; padding: 14px 16px; }
    .dp-cal  { width: 222px; }
    .dp-cal-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
    .dp-month  { font-size: 12.5px; font-weight: 600; color: var(--text); letter-spacing: .02em; }
    .dp-nav {
        background: none; border: 1px solid var(--border); color: var(--text-dim);
        width: 24px; height: 24px; border-radius: 5px; cursor: pointer; line-height: 1; font-size: 11px;
    }
    .dp-nav:hover { border-color: var(--purple); color: var(--purple); }
    .dp-nav-ghost { width: 24px; height: 24px; display: inline-block; }
    .dp-navs { display: flex; gap: 4px; min-width: 52px; }
    .dp-navs-r { justify-content: flex-end; }

    .dp-month-btn {
        background: none; border: 1px solid transparent; border-radius: 5px;
        color: var(--text); font-size: 12.5px; font-weight: 600; letter-spacing: .02em;
        font-family: var(--font-ui); cursor: pointer; padding: 3px 8px; white-space: nowrap;
    }
    .dp-month-btn:hover { border-color: var(--border2); background: rgba(167,139,250,.08); color: var(--purple); }

    .dp-pick { width: 466px; padding: 14px 16px; }
    .dp-pick-hd {
        display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;
    }
    .dp-pick-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .dp-cell {
        background: none; border: 1px solid var(--border); border-radius: var(--r);
        color: var(--text-dim); padding: 12px 0; font-size: 12.5px; cursor: pointer;
        font-family: var(--font-mono);
    }
    .dp-cell:hover  { border-color: var(--purple); color: var(--purple); background: rgba(167,139,250,.08); }
    .dp-cell-on     { background: var(--purple); border-color: var(--purple); color: var(--bg); font-weight: 600; }

    .dp-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
    .dp-dow {
        font-size: 9.5px; color: var(--text-muted); text-align: center; padding: 4px 0;
        text-transform: uppercase; letter-spacing: .04em;
    }
    .dp-day {
        aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
        font-size: 11.5px; border-radius: 5px; cursor: pointer; color: var(--text-dim);
        border: 1px solid transparent; font-family: var(--font-mono);
    }
    .dp-day:hover { background: rgba(167,139,250,.14); color: var(--text); }
    .dp-out       { cursor: default; }
    .dp-out:hover { background: none; }
    .dp-in        { background: rgba(167,139,250,.10); border-radius: 0; color: var(--text); }
    .dp-edge      { background: var(--purple); color: var(--bg); font-weight: 600; }
    .dp-edge.dp-start { border-radius: 5px 0 0 5px; }
    .dp-edge.dp-end   { border-radius: 0 5px 5px 0; }
    .dp-edge.dp-solo  { border-radius: 5px; }
    .dp-today     { border-color: rgba(167,139,250,.45); }

    .dp-ft {
        border-top: 1px solid var(--border); padding: 10px 14px;
        display: flex; align-items: center; gap: 10px;
    }
    .dp-summary { font-size: 11.5px; color: var(--text-muted); margin-right: auto; font-family: var(--font-mono); }
    .dp-summary b { color: var(--purple); font-weight: 600; }
</style>

<div class="dp-root">

    <div class="dp-field @(_open ? "dp-open" : "") @(Disabled ? "dp-disabled" : "")"
         @onclick="Toggle">
        <span class="dp-ico">▦</span>
        <span class="dp-val">@Start.ToString("yyyy-MM-dd")</span>
        <span class="dp-arrow">→</span>
        <span class="dp-val">@End.ToString("yyyy-MM-dd")</span>
        <span class="dp-chev">▾</span>
    </div>

    @if (_open)
    {
        <div class="dp-backdrop" @onclick="Cancel"></div>

        <div class="dp-pop">
            <div class="dp-body">

                @* ── Atajos ── *@
                <div class="dp-side">
                    <div class="dp-side-hdr">Atajos</div>
                    <button type="button" class="dp-sc" @onclick='() => Shortcut("7")'>Últimos 7 días</button>
                    <button type="button" class="dp-sc" @onclick='() => Shortcut("30")'>Últimos 30 días</button>
                    <button type="button" class="dp-sc" @onclick='() => Shortcut("month")'>Este mes</button>
                    <button type="button" class="dp-sc" @onclick='() => Shortcut("lastmonth")'>Mes pasado</button>
                    <button type="button" class="dp-sc" @onclick='() => Shortcut("year")'>Este año</button>
                    <button type="button" class="dp-sc" @onclick='() => Shortcut("lastyear")'>Año pasado</button>
                </div>

                @* ── Calendarios / selector de año / selector de mes ── *@
                @if (_mode == Mode.Days)
                {
                    <div class="dp-cals">
                        @for (var k = 0; k < 2; k++)
                        {
                            var month = _view.AddMonths(k);
                            var first = new DateOnly(month.Year, month.Month, 1);
                            var lead  = ((int)first.DayOfWeek + 6) % 7;              // lunes primero
                            var days  = DateTime.DaysInMonth(month.Year, month.Month);
                            var isFirstCal = k == 0;

                            <div class="dp-cal">
                                <div class="dp-cal-hd">
                                    <span class="dp-navs">
                                        @if (isFirstCal)
                                        {
                                            <button type="button" class="dp-nav" title="Año anterior" @onclick="PrevYear">«</button>
                                            <button type="button" class="dp-nav" title="Mes anterior" @onclick="PrevMonth">‹</button>
                                        }
                                    </span>

                                    <button type="button" class="dp-month-btn" title="Elegir año y mes"
                                            @onclick="() => OpenYears(month)">@MonthLabel(month) ▾</button>

                                    <span class="dp-navs dp-navs-r">
                                        @if (!isFirstCal)
                                        {
                                            <button type="button" class="dp-nav" title="Mes siguiente" @onclick="NextMonth">›</button>
                                            <button type="button" class="dp-nav" title="Año siguiente" @onclick="NextYear">»</button>
                                        }
                                    </span>
                                </div>

                                <div class="dp-grid">
                                    @foreach (var d in _dow)
                                    {
                                        <div class="dp-dow">@d</div>
                                    }
                                </div>

                                <div class="dp-grid">
                                    @for (var i = 0; i < lead; i++)
                                    {
                                        <div class="dp-day dp-out"></div>
                                    }
                                    @for (var d = 1; d <= days; d++)
                                    {
                                        var cur = new DateOnly(month.Year, month.Month, d);
                                        <div class="@DayClass(cur)" @onclick="() => Pick(cur)">@d</div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (_mode == Mode.Years)
                {
                    <div class="dp-pick">
                        <div class="dp-pick-hd">
                            <button type="button" class="dp-nav" @onclick="() => _decade -= 12">‹</button>
                            <span class="dp-month">@_decade – @(_decade + 11)</span>
                            <button type="button" class="dp-nav" @onclick="() => _decade += 12">›</button>
                        </div>
                        <div class="dp-pick-grid">
                            @for (var y = _decade; y < _decade + 12; y++)
                            {
                                var yy = y;
                                <button type="button" class="dp-cell @(yy == _pickYear ? "dp-cell-on" : "")"
                                        @onclick="() => PickYear(yy)">@yy</button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="dp-pick">
                        <div class="dp-pick-hd">
                            <button type="button" class="dp-nav" @onclick="() => _pickYear--">‹</button>
                            <span class="dp-month">@_pickYear</span>
                            <button type="button" class="dp-nav" @onclick="() => _pickYear++">›</button>
                        </div>
                        <div class="dp-pick-grid">
                            @for (var m = 1; m <= 12; m++)
                            {
                                var mm = m;
                                <button type="button" class="dp-cell @(_pickYear == _view.Year && mm == _view.Month ? "dp-cell-on" : "")"
                                        @onclick="() => PickMonth(mm)">@_monthsShort[mm - 1]</button>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="dp-ft">
                <span class="dp-summary">
                    @if (_picking)
                    {
                        <span>Selecciona la fecha final…</span>
                    }
                    else
                    {
                        <span><b>@_tmpStart.ToString("yyyy-MM-dd")</b> → <b>@_tmpEnd.ToString("yyyy-MM-dd")</b> · @DayCount() día@(DayCount() == 1 ? "" : "s")</span>
                    }
                </span>
                <button type="button" class="btn btn-sm" @onclick="Cancel">Cancelar</button>
                <button type="button" class="btn btn-primary btn-sm" @onclick="Apply" disabled="@_picking">Aplicar rango</button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public DateOnly Start { get; set; }
    [Parameter] public DateOnly End   { get; set; }
    [Parameter] public EventCallback<DateOnly> StartChanged { get; set; }
    [Parameter] public EventCallback<DateOnly> EndChanged   { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private static readonly string[] _dow =
        ["lu", "ma", "mi", "ju", "vi", "sá", "do"];

    private static readonly string[] _months =
        ["enero", "febrero", "marzo", "abril", "mayo", "junio",
         "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"];

    private static readonly string[] _monthsShort =
        ["ene", "feb", "mar", "abr", "may", "jun",
         "jul", "ago", "sep", "oct", "nov", "dic"];

    private enum Mode { Days, Years, Months }

    private bool     _open;
    private bool     _picking;      // true → esperando la fecha final
    private DateOnly _view;         // primer mes visible
    private DateOnly _tmpStart, _tmpEnd;
    private Mode     _mode = Mode.Days;
    private int      _decade;       // primer año de la página de 12
    private int      _pickYear;     // año elegido en el selector

    private static string MonthLabel(DateOnly m) => $"{_months[m.Month - 1]} {m.Year}";

    private int DayCount() => _tmpEnd.DayNumber - _tmpStart.DayNumber + 1;

    void OpenYears(DateOnly month)
    {
        _pickYear = month.Year;
        _decade   = month.Year - (((month.Year % 12) + 12) % 12);
        _mode     = Mode.Years;
    }

    void PickYear(int y)
    {
        _pickYear = y;
        _mode     = Mode.Months;
    }

    void PickMonth(int m)
    {
        _view = new DateOnly(_pickYear, m, 1);
        _mode = Mode.Days;
    }

    void PrevYear() => _view = _view.AddYears(-1);
    void NextYear() => _view = _view.AddYears(1);

    void Toggle()
    {
        if (Disabled) return;
        if (_open) { Cancel(); return; }

        _tmpStart = Start;
        _tmpEnd   = End < Start ? Start : End;
        _view     = new DateOnly(_tmpStart.Year, _tmpStart.Month, 1);
        _picking  = false;
        _mode     = Mode.Days;
        _open     = true;
    }

    void Cancel() => _open = false;

    async Task Apply()
    {
        if (_picking) return;                    // rango a medias
        _open = false;
        if (_tmpStart != Start) await StartChanged.InvokeAsync(_tmpStart);
        if (_tmpEnd   != End)   await EndChanged.InvokeAsync(_tmpEnd);
    }

    void PrevMonth() => _view = _view.AddMonths(-1);
    void NextMonth() => _view = _view.AddMonths(1);

    void Pick(DateOnly d)
    {
        if (!_picking)
        {
            _tmpStart = d; _tmpEnd = d; _picking = true;
        }
        else
        {
            if (d < _tmpStart) { _tmpEnd = _tmpStart; _tmpStart = d; }
            else               { _tmpEnd = d; }
            _picking = false;
        }
    }

    void Shortcut(string key)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        switch (key)
        {
            case "7":         _tmpEnd = today; _tmpStart = today.AddDays(-6);  break;
            case "30":        _tmpEnd = today; _tmpStart = today.AddDays(-29); break;
            case "month":     _tmpStart = new DateOnly(today.Year, today.Month, 1); _tmpEnd = today; break;
            case "lastmonth":
                var lm = new DateOnly(today.Year, today.Month, 1).AddMonths(-1);
                _tmpStart = lm;
                _tmpEnd   = lm.AddMonths(1).AddDays(-1);
                break;
            case "year":      _tmpStart = new DateOnly(today.Year, 1, 1); _tmpEnd = today; break;
            case "lastyear":  _tmpStart = new DateOnly(today.Year - 1, 1, 1); _tmpEnd = new DateOnly(today.Year - 1, 12, 31); break;
        }
        _view    = new DateOnly(_tmpStart.Year, _tmpStart.Month, 1);
        _picking = false;
        _mode    = Mode.Days;
    }

    string DayClass(DateOnly cur)
    {
        var cls = "dp-day";
        var isStart = cur == _tmpStart;
        var isEnd   = cur == _tmpEnd;

        if (cur > _tmpStart && cur < _tmpEnd) cls += " dp-in";

        if (isStart || isEnd)
        {
            cls += " dp-edge";
            cls += (isStart && isEnd) ? " dp-solo" : (isStart ? " dp-start" : " dp-end");
        }

        if (cur == DateOnly.FromDateTime(DateTime.Today)) cls += " dp-today";
        return cls;
    }
}
