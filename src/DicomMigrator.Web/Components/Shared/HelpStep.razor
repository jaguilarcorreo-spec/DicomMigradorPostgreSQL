<div style="display:flex;gap:14px;margin-bottom:20px">
    <div style="flex-shrink:0;width:28px;height:28px;border-radius:50%;
                background:color-mix(in srgb, @Color 13%, transparent);border:2px solid @Color;
                display:flex;align-items:center;justify-content:center;
                font-size:12px;font-weight:800;color:@Color;font-family:var(--font-mono)">@N</div>
    <div style="flex:1;padding-top:4px">
        <div style="font-weight:700;font-size:13px;color:var(--text);margin-bottom:6px">@Title</div>
        <div style="font-size:12px;color:var(--text-dim);line-height:1.8">@ChildContent</div>
    </div>
</div>

@code {
    [Parameter] public string N            { get; set; } = "";
    [Parameter] public string Title        { get; set; } = "";
    [Parameter] public string Color        { get; set; } = "var(--accent)";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
