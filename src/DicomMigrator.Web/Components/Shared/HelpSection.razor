<div style="background:var(--panel);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:16px">
    <div style="padding:10px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;background:color-mix(in srgb, @Color 7%, transparent)">
        <div style="width:3px;height:16px;background:@Color;border-radius:2px"></div>
        <span style="font-weight:700;font-size:13px;color:var(--text)">@Title</span>
    </div>
    <div style="padding:16px 18px">@ChildContent</div>
</div>

@code {
    [Parameter] public string Title        { get; set; } = "";
    [Parameter] public string Color        { get; set; } = "var(--accent)";
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
