    private readonly Screen[] _screens =
    [
        new("📊", "Dashboard",       "var(--accent)", "Vista global: métricas agregadas, nodos registrados y desglose de estados con barras de progreso de migración y verificación por cada migración."),
        new("⇄", "Migraciones",     "var(--purple)", "Listado de migraciones con sus dos barras de progreso. Detalle con tabs (Dashboard, Estudios, Descubrimiento, Ventana, Logs) y acciones (Editar, Eliminar)."),
        new("🔍", "Discovery Engine", "#3B82F6",       "Listado de jobs de descubrimiento. Detalle con métricas en tiempo real, tabla de particiones con paginación, inventario descubierto y exportación CSV/Excel."),
