        new("7", "Reintentos automáticos",   "var(--red)",    "Si el C-MOVE falla, el estudio pasa a RetryPending. Tras un delay configurable vuelve a la cola. Al superar MaxRetries pasa a Failed."),
    ];

    // ── Study states ────────────────────────────────────────────────────────
    private record StudyState(string Status, string Name, string Desc);
