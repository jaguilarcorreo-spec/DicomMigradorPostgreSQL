    private readonly DiscoveryStep[] _discoverySteps =
    [
        new("1", "Particionado inicial por día",  "#3B82F6",       "Se genera una partición tipo 'Day' por cada día del rango configurado. Si el rango es 2026-01-01 → 2026-06-30, se crean ~180 particiones."),
        new("2", "Worker procesa una partición",  "var(--accent)", "Lock atómico en BD asegura que cada partición la procesa un solo worker. Lanza C-FIND o QIDO-RS con el filtro de fecha y, si aplica, modalidad y franja horaria."),
