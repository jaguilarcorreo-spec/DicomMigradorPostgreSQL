    void ShowMsg(string msg, bool ok) { _actionMsg = msg; _actionOk = ok; }

    static string FormatElapsed(double totalSeconds)
    {
        var ts = TimeSpan.FromSeconds(totalSeconds);
        if (ts.TotalSeconds < 60)  return $"{(int)ts.TotalSeconds}s";
        if (ts.TotalMinutes < 60)  return $"{(int)ts.TotalMinutes}m {ts.Seconds}s";
        return $"{(int)ts.TotalHours}h {ts.Minutes}m {ts.Seconds}s";
    }

    static string StatusColor(string status) => status switch
    {
        "Running"   => "var(--accent)",
        "Completed" => "var(--purple)",
        "Paused"    => "var(--yellow)",
        "Failed"    => "var(--red)",
        _           => "var(--border2)"
    };
