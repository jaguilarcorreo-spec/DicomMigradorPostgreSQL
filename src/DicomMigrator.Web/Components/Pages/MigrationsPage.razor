    // ── Header delete (double confirmation, blocked while Running) ───────────
    void RequestDeleteMigration()
    {
        _delMsg = ""; _editingMig = false;
        if (_detail is null) return;
        if (_detail.Status == "Running")
        {
            _delMsg = "La migración se está ejecutando. Debes pausarla antes de poder eliminarla.";
            _delStep = 0;
            return;
        }
        // Stop auto-refresh while the confirmation dialog is open —
        // avoids race conditions between the timer and the delete click.
        StopAutoRefresh();
        _delStep = 1;
    }

    async Task DeleteMigrationConfirmed()
    {
        if (_detail is null) return;
        // Re-verify status with a fresh DB read before destroying data
        var fresh = await MigrationRepo.GetByIdAsync(_detail.Id);
        if (fresh?.Status == "Running")
        {
            _delMsg = "La migración se está ejecutando. Debes pausarla antes de poder eliminarla.";
            _delStep = 0;
            return;
        }
        _deleting = true;
        var id = _detail.Id;
        try
        {
            await MigrationRepo.DeleteAsync(id);

            // Borrar una migración libera muchas filas (estudios + auditoría). Recuperar
            // ese espacio del fichero con un vacuum incremental, en segundo plano para
            // no bloquear la navegación.
            _ = Task.Run(async () =>
            {
                try
                {
                    using var scope = ScopeFactory.CreateScope();
                    var maintenance = scope.ServiceProvider
                        .GetRequiredService<DicomMigrator.Infrastructure.Data.DatabaseMaintenance>();
                    await maintenance.IncrementalVacuumAsync();
                }
                catch { /* no crítico */ }
            });

            _delStep = 0;
            BackToList();
        }
        catch (Exception ex)
        {
            _delMsg = ex.Message;
            _delStep = 0;
        }
        finally
        {
            // Always reset — ensures the button is re-enabled if delete fails
            _deleting = false;
        }
    }

    // ── Edit migration properties ────────────────────────────────────────────
    void OpenEditMigration()
    {
        if (_detail is null) return;
        _delStep = 0; _delMsg = ""; _editMigError = "";
        _emName       = _detail.Name;
        _emDesc       = _detail.Description ?? "";
        _emThreads    = _detail.WorkerThreads;
        _emRetries    = _detail.MaxRetries;
        _emRetryDelay = _detail.RetryDelaySeconds;
        _emPriority   = _detail.ModalityPriority ?? "";
        _emOldestFirst = _detail.OldestFirst;
        _editingMig   = true;
    }

    async Task SaveEditMigrationAsync()
    {
        if (_detail is null) return;
        if (string.IsNullOrWhiteSpace(_emName)) { _editMigError = "El nombre es obligatorio."; return; }
        _actionBusy = true; _editMigError = "";
        try
        {
            _detail.Name             = _emName.Trim();
            _detail.Description      = string.IsNullOrWhiteSpace(_emDesc) ? string.Empty : _emDesc.Trim();
            _detail.WorkerThreads    = _emThreads;
            _detail.MaxRetries       = _emRetries;
            _detail.RetryDelaySeconds = _emRetryDelay;
            _detail.ModalityPriority = _emPriority?.Trim() ?? "";
            _detail.OldestFirst      = _emOldestFirst;
            await MigrationRepo.UpdateAsync(_detail);
            _editingMig = false;
            ShowMsg("Propiedades de la migración actualizadas.", true);
            await RefreshDetailAsync();
        }
        catch (Exception ex) { _editMigError = ex.Message; }
        finally { _actionBusy = false; }
    }

