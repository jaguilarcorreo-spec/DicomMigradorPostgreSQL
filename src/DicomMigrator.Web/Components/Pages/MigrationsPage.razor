    async Task SaveWindowAsync()
    {
        if (_detail is null) return;
        _actionBusy = true;
        try
        {
            var updated = await MigrationRepo.GetByIdAsync(_detail.Id);
            if (updated is null) return;
            updated.Window = new ExecutionWindow
            {
                MigrationId = _detail.Id,
                EnabledDays = string.Join(",", _enabledDays.OrderBy(d => d)),
                StartTime   = TimeOnly.Parse(_winStart),
                EndTime     = TimeOnly.Parse(_winEnd),
                TimeZoneId  = _winTz,
            };
            await MigrationRepo.UpdateAsync(updated);
            _detail = updated;
            ShowMsg("Ventana guardada.", true);
        }
        catch (Exception ex) { ShowMsg($"Error: {ex.Message}", false); }
        finally { _actionBusy = false; }
    }

