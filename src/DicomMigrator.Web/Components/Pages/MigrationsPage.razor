    /// <summary>Parar: detiene el proceso. Los hilos en curso terminan su estudio
    /// actual (no se interrumpen), pero no se toma más trabajo. Deja estado Cancelled;
    /// con Iniciar se puede relanzar.</summary>
    async Task StopMigrationAsync()
    {
        if (_detail is null) return;
        _actionBusy = true;
        try
        {
            await Worker.PauseAsync(_detail.Id);   // cancela el token: los workers salen al terminar el actual
            await MigrationRepo.UpdateStatusAsync(_detail.Id, "Cancelled");
            await RefreshDetailAsync();
            StopAutoRefresh();
            ShowMsg("Migración detenida.", true);
        }
        catch (Exception ex) { ShowMsg($"Error: {ex.Message}", false); }
        finally { _actionBusy = false; }
    }

