@page "/cambiar-password"
@layout DicomMigrator.Web.Components.Layout.BareLayout

@* Render estático, igual que el login: el cambio de contraseña se envía como POST
   normal. Requiere estar autenticado ([Authorize] heredado de Pages/_Imports). *@

@using Microsoft.AspNetCore.Authentication
@using DicomMigrator.Web.Services
@inject UserAuthService Auth
@inject NavigationManager Nav

<PageTitle>Cambiar contraseña — MOVE</PageTitle>

<style>
    .cp-wrap  { min-height: 100vh; display: flex; align-items: center; justify-content: center;
                padding: 24px; background: var(--bg); }
    .cp-card  { width: 100%; max-width: 400px; background: var(--panel);
                border: 1px solid var(--border); border-radius: var(--r2); padding: 28px;
                box-shadow: 0 18px 40px rgba(0,0,0,.45); }
    .cp-h     { font-size: 15px; font-weight: 600; margin: 0 0 6px; }
    .cp-sub   { font-size: 12px; color: var(--text-dim); margin: 0 0 18px; line-height: 1.5; }
    .cp-group { margin-bottom: 13px; }
    .cp-label { display: block; font-size: 12px; color: var(--text-dim); margin-bottom: 6px; }
    .cp-input { width: 100%; background: var(--bg); border: 1px solid var(--border);
                border-radius: var(--r); color: var(--text); padding: 9px 11px;
                font-size: 13px; outline: none; font-family: var(--font-ui); }
    .cp-input:focus { border-color: var(--purple); box-shadow: 0 0 0 3px rgba(167,139,250,.12); }
    .cp-btn   { width: 100%; margin-top: 6px; padding: 10px; font-size: 13px; font-weight: 600;
                background: var(--accent2); border: 1px solid var(--accent2); color: #fff;
                border-radius: var(--r); cursor: pointer; font-family: var(--font-ui); }
    .cp-btn:hover { background: var(--accent); border-color: var(--accent); }
    .cp-alert { background: rgba(239,68,68,.08); border: 1px solid rgba(239,68,68,.3);
                color: #fca5a5; border-radius: var(--r); padding: 9px 11px;
                font-size: 12px; margin-bottom: 14px; line-height: 1.5; }
</style>

<div class="cp-wrap">
    <div class="cp-card">
        <h1 class="cp-h">Cambiar contraseña</h1>
        <p class="cp-sub">
            Mínimo 8 caracteres y distinta de la actual.
        </p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="cp-alert">@_error</div>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="SubmitAsync" FormName="changepwd">
            <DataAnnotationsValidator />

            <div class="cp-group">
                <label class="cp-label" for="c">Contraseña actual</label>
                <InputText id="c" type="password" class="cp-input" @bind-Value="Input.Current"
                           autocomplete="current-password" />
            </div>
            <div class="cp-group">
                <label class="cp-label" for="n">Nueva contraseña</label>
                <InputText id="n" type="password" class="cp-input" @bind-Value="Input.New"
                           autocomplete="new-password" />
            </div>
            <div class="cp-group">
                <label class="cp-label" for="r">Repetir nueva contraseña</label>
                <InputText id="r" type="password" class="cp-input" @bind-Value="Input.Repeat"
                           autocomplete="new-password" />
            </div>

            <button type="submit" class="cp-btn">Guardar</button>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter]      private HttpContext        HttpContext { get; set; } = default!;
    [SupplyParameterFromForm] private ChangePasswordInput Input      { get; set; } = new();

    private string? _error;

    public sealed class ChangePasswordInput
    {
        public string Current { get; set; } = string.Empty;
        public string New     { get; set; } = string.Empty;
        public string Repeat  { get; set; } = string.Empty;
    }

    private async Task SubmitAsync()
    {
        var userName = HttpContext.User.Identity?.Name;
        if (string.IsNullOrEmpty(userName))
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        _error = await Auth.ChangePasswordAsync(userName, Input.Current, Input.New, Input.Repeat);
        if (_error is not null) return;

        // Se cierra la sesión para forzar un acceso limpio con la contraseña nueva:
        // así la cookie no conserva el estado "debe cambiar contraseña".
        await HttpContext.SignOutAsync(
            Microsoft.AspNetCore.Authentication.Cookies.CookieAuthenticationDefaults.AuthenticationScheme);
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
